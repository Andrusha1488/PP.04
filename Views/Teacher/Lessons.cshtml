@{
    ViewData["Title"] = "Занятия";
    var assignment = ViewBag.Assignment as StudentDiaryWeb.Models.TeacherAssignment;
    var allLessons = ViewBag.AllLessons as List<StudentDiaryWeb.Models.Lesson>
                      ?? new List<StudentDiaryWeb.Models.Lesson>();
    var list = Model as List<StudentDiaryWeb.Models.Lesson>
                      ?? new List<StudentDiaryWeb.Models.Lesson>();
    int hoursC = ViewBag.HoursConducted != null ? (int)ViewBag.HoursConducted : 0;
    int hoursP = ViewBag.HoursPlanned != null ? (int)ViewBag.HoursPlanned : 0;
    string filterType = ViewBag.FilterType ?? "";
    string dateFrom = ViewBag.DateFrom ?? "";
    string dateTo = ViewBag.DateTo ?? "";

    var lessonTypes = new[] { "Лекция", "Практика", "Лабораторная работа",
                              "Зачёт", "Контрольная работа" };
}

<div class="page-header">
    <div>
        <div class="page-title">📋 Занятия</div>
        <div class="page-subtitle">@assignment?.GroupName · @assignment?.SubjectName</div>
    </div>
    <div style="display:flex;gap:8px;">
        <a href="/Teacher/CreateLesson?assignmentId=@assignment?.AssignmentID" class="btn btn-primary">+ Новое занятие</a>
        <a href="/Teacher/Journal?assignmentId=@assignment?.AssignmentID" class="btn btn-secondary">📓 Журнал</a>
        <a href="/Teacher/Index" class="btn btn-secondary">← Назад</a>
    </div>
</div>

@* ── Прогресс часов ── *@
<div style="background:white;border:1px solid #e5e7eb;border-radius:10px;
            padding:16px 20px;margin-bottom:16px;display:flex;gap:24px;flex-wrap:wrap;align-items:center;">
    <div style="font-size:13px;color:#6b7280;">
        Всего занятий: <strong>@allLessons.Count</strong>
    </div>
    <div style="font-size:13px;color:#6b7280;">
        Часов проведено: <strong>@hoursC</strong> из <strong>@hoursP</strong>
    </div>
    @if (hoursP > 0)
    {
        int pct = (int)Math.Round(hoursC * 100.0 / hoursP);
        string c = pct >= 90 ? "#16a34a" : pct >= 60 ? "#2563eb" : "#dc2626";
        <div style="font-size:13px;color:@c;font-weight:600;">@pct%</div>
        if (hoursC < hoursP * 0.9)
        {
            <div class="badge badge-warning">⚠ Отставание от плана</div>
        }
    }
</div>

@* ── Панель фильтров ── *@
<form method="get" action="/Teacher/Lessons"
      style="background:white;border:1px solid #e5e7eb;border-radius:10px;
             padding:16px 20px;margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
    <input type="hidden" name="assignmentId" value="@assignment?.AssignmentID">

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Тип занятия</div>
        <select name="filterType"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
            <option value="">Все типы</option>
            @foreach (var t in lessonTypes)
            {
                if (filterType == t)
                {
                    <option value="@t" selected>@t</option>
                }
                else
                {
                    <option value="@t">@t</option>
                }
            }
        </select>
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Дата с</div>
        <input type="date" name="dateFrom" value="@dateFrom"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Дата по</div>
        <input type="date" name="dateTo" value="@dateTo"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
    </div>

    <button type="submit" class="btn btn-primary">Применить</button>
    @if (!string.IsNullOrEmpty(filterType) || !string.IsNullOrEmpty(dateFrom) || !string.IsNullOrEmpty(dateTo))
    {
        <a href="/Teacher/Lessons?assignmentId=@assignment?.AssignmentID" class="btn btn-secondary">✕ Сбросить</a>
    }
    <div style="margin-left:auto;font-size:13px;color:#6b7280;align-self:center;">
        Показано: <strong>@list.Count</strong> из <strong>@allLessons.Count</strong>
    </div>
</form>

<div class="table-card">
    <table id="lessonsTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Дата</th>
                <th>Пара</th>
                <th>Тема занятия</th>
                <th>Тип</th>
                <th>Часов</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @{
                int idx = 1;
            }
            @foreach (var l in list)
            {
                <tr>
                    <td style="color:#9ca3af;">@idx</td>
                    <td>@l.LessonDate.ToString("dd.MM.yyyy")</td>
                    <td style="text-align:center;">@l.LessonNumber</td>
                    <td>
                        @if (string.IsNullOrEmpty(l.Topic))
                        {
                            <span style="color:#9ca3af;">— не указана —</span>
                        }
                        else
                        {

                            @l.Topic
                        }
                    </td>
                    <td><span class="badge badge-info">@l.LessonType</span></td>
                    <td style="text-align:center;">@l.HoursCount</td>
                    <td>
                        <a href="/Teacher/FillLesson?lessonId=@l.LessonID" class="btn btn-success btn-sm">✏ Оценки</a>
                        <a href="/Teacher/EditLesson?lessonId=@l.LessonID" class="btn btn-secondary btn-sm">Изменить</a>
                        <form method="post" action="/Teacher/DeleteLesson"
                              data-confirm="Удалить занятие и все оценки за него?"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="lessonId" value="@l.LessonID">
                            <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                        </form>
                    </td>
                </tr>
                idx++;
            }
            @if (!list.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:32px;color:#9ca3af;">
                        @if (!allLessons.Any())
                        {
                            <span>Занятий ещё нет</span>
                        }
                        else
                        {

                            <span>По выбранным фильтрам занятий не найдено</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
