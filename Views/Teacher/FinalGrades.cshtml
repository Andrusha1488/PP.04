@{
    ViewData["Title"] = "Итоговые оценки";
    var assignment = ViewBag.Assignment as StudentDiaryWeb.Models.TeacherAssignment;
    var allList = Model as List<StudentDiaryWeb.Models.FinalGrade>
                      ?? new List<StudentDiaryWeb.Models.FinalGrade>();
    string filterGrade = ViewBag.FilterGrade ?? "";
    string filterLocked = ViewBag.FilterLocked ?? "";

    // Клиентская фильтрация
    var list = allList
        .Where(f => string.IsNullOrEmpty(filterGrade) || f.FinalGradeValue == filterGrade)
        .Where(f => filterLocked == "locked" ? f.IsLocked :
                    filterLocked == "unlocked" ? !f.IsLocked : true)
        .ToList();
}

<div class="page-header">
    <div>
        <div class="page-title">⭐ Итоговые оценки</div>
        <div class="page-subtitle">@assignment?.GroupName · @assignment?.SubjectName · @assignment?.SemesterName</div>
    </div>
    <div style="display:flex;gap:8px;">
        <a href="/Teacher/CreateFinalGrades?assignmentId=@assignment?.AssignmentID" class="btn btn-primary">✏ Выставить / изменить</a>
        <a href="/Teacher/Journal?assignmentId=@assignment?.AssignmentID" class="btn btn-secondary">← Журнал</a>
    </div>
</div>

@* Фильтры *@
<form method="get" action="/Teacher/FinalGrades"
      style="background:white;border:1px solid #e5e7eb;border-radius:10px;
             padding:14px 20px;margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
    <input type="hidden" name="assignmentId" value="@assignment?.AssignmentID">

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Оценка</div>
        <select name="filterGrade"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
            @{
                var grades = new[] { "", "5", "4", "3", "2", "зач", "незач" };
                var labels = new[] { "Все оценки", "5", "4", "3", "2", "Зачёт", "Незачёт" };
            }
            @for (int i = 0; i < grades.Length; i++)
            {
                if (filterGrade == grades[i])
                {
                    <option value="@grades[i]" selected>@labels[i]</option>
                }
                else
                {
                    <option value="@grades[i]">@labels[i]</option>
                }
            }
        </select>
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Статус</div>
        <select name="filterLocked"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
            @{
                var lockVals = new[] { "", "unlocked", "locked" };
                var lockLabels = new[] { "Все", "Открытые", "Заблокированные" };
            }
            @for (int i = 0; i < lockVals.Length; i++)
            {
                if (filterLocked == lockVals[i])
                {
                    <option value="@lockVals[i]" selected>@lockLabels[i]</option>
                }
                else
                {
                    <option value="@lockVals[i]">@lockLabels[i]</option>
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Применить</button>
    @if (!string.IsNullOrEmpty(filterGrade) || !string.IsNullOrEmpty(filterLocked))
    {
        <a href="/Teacher/FinalGrades?assignmentId=@assignment?.AssignmentID" class="btn btn-secondary">✕ Сбросить</a>
    }
    <div style="margin-left:auto;font-size:13px;color:#6b7280;align-self:center;">
        Показано: <strong>@list.Count</strong> из <strong>@allList.Count</strong>
    </div>
</form>

@* Сводка *@
@if (allList.Any())
{
    <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
        @{
            var gradeGroups = allList.GroupBy(f => f.FinalGradeValue).OrderByDescending(g => g.Key);
        }
        @foreach (var g in gradeGroups)
        {
            string col = g.Key == "5" ? "#16a34a" : g.Key == "4" ? "#2563eb" : g.Key == "3" ? "#d97706" : g.Key == "зач" ? "#16a34a" : "#dc2626";
            <div style="background:white;border:1px solid #e5e7eb;border-radius:8px;
                                padding:12px 20px;text-align:center;min-width:80px;">
                <div style="font-size:24px;font-weight:700;color:@col;">@g.Key</div>
                <div style="font-size:12px;color:#6b7280;">@g.Count() чел.</div>
            </div>
        }
    </div>
}

<div class="table-card">
    <table>
        <thead>
            <tr>
                <th>Студент</th>
                <th style="text-align:center;">Ср. балл</th>
                <th style="text-align:center;">Итоговая</th>
                <th>Форма</th>
                <th>Дата</th>
                <th style="text-align:center;">Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fg in list)
            {
                string gradeColor = fg.FinalGradeValue == "5" ? "#16a34a"
                : fg.FinalGradeValue == "4" ? "#2563eb"
                : fg.FinalGradeValue == "3" ? "#d97706" : "#dc2626";
                <tr>
                    <td>@fg.StudentName</td>
                    <td style="text-align:center;color:#6b7280;">
                        @(fg.AverageGrade.HasValue? fg.AverageGrade.Value.ToString("0.0") : "—")
                    </td>
                    <td style="text-align:center;font-weight:700;font-size:15px;color:@gradeColor;">
                        @fg.FinalGradeValue
                    </td>
                    <td>@fg.GradeForm</td>
                    <td>@fg.GradeDate.ToString("dd.MM.yyyy")</td>
                    <td style="text-align:center;">
                        @if (fg.IsLocked)
                        {
                            <span class="badge badge-danger">🔒 Закрыто</span>
                        }
                        else
                        {

                            <span class="badge badge-success">Открыто</span>
                        }
                    </td>
                    <td>
                        @if (!fg.IsLocked)
                        {
                            <form method="post" action="/Teacher/DeleteFinalGrade"
                                  data-confirm="Удалить итоговую оценку?"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="finalGradeId" value="@fg.FinalGradeID">
                                <input type="hidden" name="assignmentId" value="@assignment?.AssignmentID">
                                <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!list.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:32px;color:#9ca3af;">
                        @(allList.Any() ? "По выбранным фильтрам ничего не найдено" : "Итоговые оценки ещё не выставлены")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
