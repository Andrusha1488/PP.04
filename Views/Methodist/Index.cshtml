@{
    ViewData["Title"] = "Методист — главная";
    var model = Model as StudentDiaryWeb.Models.MethodistDashboard;
    var semesters = ViewBag.Semesters as List<(int ID, string Name)>
                    ?? new List<(int, string)>();
    var teachers = ViewBag.Teachers as List<(int ID, string Name)>
                    ?? new List<(int, string)>();
    int selSem = ViewBag.SelectedSemester != null ? (int)ViewBag.SelectedSemester : 0;
    int selTch = ViewBag.SelectedTeacher != null ? (int)ViewBag.SelectedTeacher : 0;

    int allCount = model?.AllAssignments.Count ?? 0;
    int notRevCount = model?.NotReviewedThisMonth.Count ?? 0;
    int behindCount = model?.BehindSchedule.Count ?? 0;
}

<div class="page-header">
    <div>
        <div class="page-title">Контроль журналов</div>
        <div class="page-subtitle">@User.FindFirst("FullName")?.Value</div>
    </div>
    <a href="/Methodist/Report" class="btn btn-secondary">📊 Сводный отчёт</a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-number">@allCount</div>
        <div class="stat-label">Всего журналов</div>
    </div>
    <div class="stat-card" style="border-color:@(notRevCount > 0 ? "#fecaca" : "#e5e7eb")">
        <div class="stat-number" style="color:@(notRevCount > 0 ? "#dc2626" : "#1e40af")">
            @notRevCount
        </div>
        <div class="stat-label">Не проверено в этом месяце</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:@(behindCount > 0 ? "#d97706" : "#1e40af")">
            @behindCount
        </div>
        <div class="stat-label">Отстают от плана (&gt;10%)</div>
    </div>
</div>

@if (notRevCount > 0)
{
    <div class="alert alert-warning">⚠ @notRevCount журналов не проверено в текущем месяце</div>
}

@* ── Панель фильтров ── *@
<form method="get" action="/Methodist/Index"
      style="background:white;border:1px solid #e5e7eb;border-radius:10px;
             padding:16px 20px;margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Семестр</div>
        <select name="semesterId"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;min-width:200px;">
            <option value="">Все семестры</option>
            @foreach (var s in semesters)
            {
                if (selSem == s.ID)
                {
                    <option value="@s.ID" selected>@s.Name</option>
                }
                else
                {
                    <option value="@s.ID">@s.Name</option>
                }
            }
        </select>
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Преподаватель</div>
        <select name="teacherId"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;min-width:180px;">
            <option value="">Все преподаватели</option>
            @foreach (var t in teachers)
            {
                if (selTch == t.ID)
                {
                    <option value="@t.ID" selected>@t.Name</option>
                }
                else
                {
                    <option value="@t.ID">@t.Name</option>
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Применить</button>
    @if (selSem > 0 || selTch > 0)
    {
        <a href="/Methodist/Index" class="btn btn-secondary">✕ Сбросить</a>
    }
    <div style="margin-left:auto;font-size:13px;color:#6b7280;align-self:center;">
        Показано: <strong>@allCount</strong>
    </div>
</form>

<div class="table-card">
    <div class="table-header">
        <div class="table-title">Все журналы</div>
        <div class="search-box">
            <input type="text" placeholder="Быстрый поиск…" data-search="assignTable">
        </div>
    </div>
    <table id="assignTable">
        <thead>
            <tr>
                <th>Преподаватель</th>
                <th>Группа</th>
                <th>Предмет</th>
                <th>Семестр</th>
                <th>Часов</th>
                <th>Прогресс</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (model != null)
            {
                @foreach (var a in model.AllAssignments)
                {
                    int pct = a.HoursTotal > 0
                    ? (int)Math.Round(a.HoursConducted * 100.0 / a.HoursTotal) : 0;
                    bool behind = a.HoursTotal > 0 && a.HoursConducted < a.HoursTotal * 0.9m;
                    string barColor = pct >= 90 ? "#16a34a" : pct >= 60 ? "#2563eb" : "#dc2626";
                    <tr>
                        <td>@a.TeacherName</td>
                        <td><strong>@a.GroupName</strong></td>
                        <td>@a.SubjectName</td>
                        <td>@a.SemesterName</td>
                        <td>@a.HoursConducted / @a.HoursTotal</td>
                        <td>
                            <div style="background:#f3f4f6;border-radius:4px;height:8px;
                                                width:80px;overflow:hidden;display:inline-block;vertical-align:middle;">
                                <div style="width:@(Math.Min(pct, 100))%;background:@barColor;
                                                    height:100%;border-radius:4px;"></div>
                            </div>
                            @if (behind)
                            {
                                <span class="badge badge-warning" style="margin-left:4px;">⚠</span>
                            }
                        </td>
                        <td>
                            <a href="/Methodist/Journal?assignmentId=@a.AssignmentID"
                               class="btn btn-primary btn-sm">📓 Открыть</a>
                        </td>
                    </tr>
                }
            }
            @if (allCount == 0)
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:32px;color:#9ca3af;">
                        Назначений не найдено
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
