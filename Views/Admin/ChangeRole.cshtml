@{
    ViewData["Title"] = "Изменить роль";
    var user = Model as StudentDiaryWeb.Models.AppUser;
    var roles = ViewBag.Roles as List<(int ID, string Name)> ?? new List<(int, string)>();
}

<div class="page-header">
    <div class="page-title">👤 Изменить роль пользователя</div>
    <a href="/Admin/Users" class="btn btn-secondary">← Назад</a>
</div>

<div style="background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:14px 18px;margin-bottom:20px;font-size:13px;color:#92400e;">
    ⚠ При смене роли старый профиль (преподавателя или методиста) будет удалён и создан новый.
</div>

<div class="form-card">
    <div style="margin-bottom:20px;padding:14px;background:#f9fafb;border-radius:8px;">
        <div style="font-size:13px;color:#6b7280;margin-bottom:4px;">Пользователь</div>
        <div style="font-size:16px;font-weight:700;">@user?.Login</div>
        <div style="font-size:13px;color:#6b7280;margin-top:4px;">
            Текущая роль: <span class="badge badge-info">@user?.RoleName</span>
        </div>
    </div>

    <form method="post" action="/Admin/ChangeRole">
        @Html.AntiForgeryToken()
        <input type="hidden" name="userID" value="@user?.UserID">

        <div class="form-group">
            <label>Новая роль</label>
            <select name="newRoleID" id="newRoleSelect" onchange="toggleProfileFields(this.value)">
                @foreach (var r in roles)
                {
                    if (user?.RoleID == r.ID)
                    {
                        <option value="@r.ID" selected>@r.Name</option>
                    }
                    else
                    {
                        <option value="@r.ID">@r.Name</option>
                    }
                }
            </select>
        </div>

        <div id="profileFields">
            <div class="form-group">
                <label>Фамилия</label>
                <input type="text" name="lastName" placeholder="Иванов" maxlength="100">
            </div>
            <div class="form-group">
                <label>Имя</label>
                <input type="text" name="firstName" placeholder="Иван" maxlength="100">
            </div>
            <div class="form-group">
                <label>Отчество</label>
                <input type="text" name="patronymic" placeholder="Иванович" maxlength="100">
            </div>
            <div class="form-hint" style="margin-bottom:16px;">ФИО нужно только при смене на роль Преподаватель или Методист</div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-warning">Изменить роль</button>
            <a href="/Admin/Users" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

<script>
    function toggleProfileFields(roleId) {
        var fields = document.getElementById('profileFields');
        fields.style.display = (roleId == '2' || roleId == '3') ? 'block' : 'none';
    }
    toggleProfileFields(document.getElementById('newRoleSelect').value);
</script>
