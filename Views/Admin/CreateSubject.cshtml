@* Admin/CreateSubject.cshtml *@
@{
    ViewData["Title"] = "Новый предмет";
}

<div class="page-header">
    <div class="page-title">📚 Новый предмет</div>
    <a href="/Admin/Subjects" class="btn btn-secondary">← Назад</a>
</div>

<div class="form-card">
    <form method="post" action="/Admin/CreateSubject">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Название предмета</label>
            <input type="text" name="SubjectName" placeholder="Например: Электротехника" maxlength="200" required>
        </div>
        <div class="form-group">
            <label>Код / описание</label>
            <input type="text" name="Description" placeholder="Например: ОП.05" maxlength="500">
            <div class="form-hint">Код дисциплины по учебному плану</div>
        </div>
        <div class="form-group">
            <label>Часов по плану</label>
            <input type="number" name="HoursTotal" value="72" min="0" max="1000">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Добавить</button>
            <a href="/Admin/Subjects" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>
