@{
    ViewData["Title"] = "Студенты";
    var list = Model as List<StudentDiaryWeb.Models.Student>
                   ?? new List<StudentDiaryWeb.Models.Student>();
    var groups = ViewBag.Groups as List<(int ID, string Name)>
                   ?? new List<(int, string)>();
    int selGroup = ViewBag.SelectedGroup != null ? (int)ViewBag.SelectedGroup : 0;
    string selStatus = ViewBag.SelectedStatus ?? "";
    string search = ViewBag.Search ?? "";
}

<div class="page-header">
    <div class="page-title">🎓 Студенты</div>
    <a href="/Admin/CreateStudent" class="btn btn-primary">+ Новый студент</a>
</div>

@* ── Панель фильтров ── *@
<form method="get" action="/Admin/Students"
      style="background:white;border:1px solid #e5e7eb;border-radius:10px;
             padding:16px 20px;margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Поиск по ФИО</div>
        <input type="text" name="search" value="@search"
               placeholder="Иванов Иван…"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;width:200px;">
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Группа</div>
        <select name="groupId"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
            <option value="">Все группы</option>
            @foreach (var g in groups)
            {
                if (selGroup == g.ID)
                {
                    <option value="@g.ID" selected>@g.Name</option>
                }
                else
                {
                    <option value="@g.ID">@g.Name</option>
                }
            }
        </select>
    </div>

    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Статус</div>
        <select name="status"
                style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;">
            @if (selStatus == "")
            {
                <option value="" selected>Все</option>
            }
            else
            {
                <option value="">Все</option>
            }

            @if (selStatus == "active")
            {
                <option value="active" selected>Активные</option>
            }
            else
            {
                <option value="active">Активные</option>
            }

            @if (selStatus == "fired")
            {
                <option value="fired" selected>Отчисленные</option>
            }
            else
            {
                <option value="fired">Отчисленные</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Применить</button>
    @if (selGroup > 0 || !string.IsNullOrEmpty(selStatus) || !string.IsNullOrEmpty(search))
    {
        <a href="/Admin/Students" class="btn btn-secondary">✕ Сбросить</a>
    }
    <div style="margin-left:auto;font-size:13px;color:#6b7280;align-self:center;">
        Найдено: <strong>@list.Count</strong>
    </div>
</form>

<div class="table-card">
    <table id="studentsTable">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Группа</th>
                <th>Дата зачисления</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in list)
            {
                <tr>
                    <td><strong>@s.FullName</strong></td>
                    <td>@s.GroupName</td>
                    <td style="color:#6b7280;">@s.EnrollmentDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        @if (s.IsActive)
                        {
                            <span class="badge badge-success">Активен</span>
                        }
                        else
                        {

                            <span class="badge badge-danger">Отчислен</span>
                        }
                    </td>
                    <td>
                        <a href="/Admin/EditStudent?id=@s.StudentID" class="btn btn-secondary btn-sm">Изменить</a>
                        <form method="post" action="/Admin/DeleteStudent"
                              data-confirm="Удалить студента «@s.FullName»?"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@s.StudentID">
                            <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!list.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;padding:32px;color:#9ca3af;">
                        Студентов не найдено
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
