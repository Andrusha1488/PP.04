@{
    ViewData["Title"] = "Новая группа";
}

<div class="page-header">
    <div class="page-title">👥 Новая группа</div>
    <a href="/Admin/Groups" class="btn btn-secondary">← Назад</a>
</div>

<div class="form-card">
    <form method="post" action="/Admin/CreateGroup">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Название группы</label>
            <input type="text" name="GroupName"
                   placeholder="Например: 21П-1" maxlength="50" required>
        </div>

        <div class="form-group">
            <label>Курс</label>
            <select name="CourseYear">
                <option value="1">1 курс</option>
                <option value="2">2 курс</option>
                <option value="3">3 курс</option>
                <option value="4">4 курс</option>
            </select>
        </div>

        <div class="form-group">
            <label>Специальность</label>
            <input type="text" name="Specialty"
                   placeholder="Например: Программирование в компьютерных системах"
                   maxlength="200">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Создать</button>
            <a href="/Admin/Groups" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>
