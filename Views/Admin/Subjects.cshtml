@{
    ViewData["Title"] = "Предметы";
    var allList = Model as List<StudentDiaryWeb.Models.Subject>
                  ?? new List<StudentDiaryWeb.Models.Subject>();
    string search = ViewBag.Search ?? "";
    int minHours = ViewBag.MinHours != null ? (int)ViewBag.MinHours : 0;
    int maxHours = ViewBag.MaxHours != null ? (int)ViewBag.MaxHours : 9999;

    var list = allList
        .Where(s => string.IsNullOrEmpty(search) ||
                    s.SubjectName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    s.Description.Contains(search, StringComparison.OrdinalIgnoreCase))
        .Where(s => minHours == 0 || s.HoursTotal >= minHours)
        .Where(s => maxHours == 9999 || s.HoursTotal <= maxHours)
        .ToList();
}

<div class="page-header">
    <div class="page-title">📚 Предметы</div>
    <a href="/Admin/CreateSubject" class="btn btn-primary">+ Новый предмет</a>
</div>

<form method="get" action="/Admin/Subjects"
      style="background:white;border:1px solid #e5e7eb;border-radius:10px;
             padding:14px 20px;margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Поиск по названию / коду</div>
        <input type="text" name="search" value="@search"
               placeholder="Электротехника, ОП.05…"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;width:200px;">
    </div>
    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">Часов от</div>
        <input type="number" name="minHours" value="@(minHours > 0 ? minHours.ToString() : "")"
               min="0" max="1000" placeholder="0"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;width:80px;">
    </div>
    <div>
        <div style="font-size:12px;color:#6b7280;margin-bottom:4px;">до</div>
        <input type="number" name="maxHours" value="@(maxHours < 9999 ? maxHours.ToString() : "")"
               min="0" max="1000" placeholder="∞"
               style="padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;width:80px;">
    </div>
    <button type="submit" class="btn btn-primary">Применить</button>
    @if (!string.IsNullOrEmpty(search) || minHours > 0 || maxHours < 9999)
    {
        <a href="/Admin/Subjects" class="btn btn-secondary">✕ Сбросить</a>
    }
    <div style="margin-left:auto;font-size:13px;color:#6b7280;align-self:center;">
        Показано: <strong>@list.Count</strong> из <strong>@allList.Count</strong>
    </div>
</form>

<div class="table-card">
    <table id="subjectsTable">
        <thead>
            <tr>
                <th>Название</th>
                <th>Код / описание</th>
                <th style="text-align:center;">Часов</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in list)
            {
                <tr>
                    <td><strong>@s.SubjectName</strong></td>
                    <td style="color:#6b7280;">@(string.IsNullOrEmpty(s.Description) ? "—" : s.Description)</td>
                    <td style="text-align:center;">@s.HoursTotal</td>
                    <td>
                        <a href="/Admin/EditSubject?id=@s.SubjectID" class="btn btn-secondary btn-sm">Изменить</a>
                        <form method="post" action="/Admin/DeleteSubject"
                              data-confirm="Удалить предмет «@s.SubjectName»?"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@s.SubjectID">
                            <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!list.Any())
            {
                <tr><td colspan="4" style="text-align:center;padding:32px;color:#9ca3af;">Предметов не найдено</td></tr>
            }
        </tbody>
    </table>
</div>
