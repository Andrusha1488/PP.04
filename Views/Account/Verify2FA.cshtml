@model StudentDiaryWeb.Models.TwoFactorViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Подтверждение входа — Электронный дневник</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f0f4f8;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            text-align: center;
        }

        .icon {
            width: 64px;
            height: 64px;
            background: #eff6ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 28px;
        }

        h1 {
            font-size: 22px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 8px;
        }

        .email-hint {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 28px;
            line-height: 1.5;
        }

            .email-hint strong {
                color: #111827;
            }

        .error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: left;
        }

        .info {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            color: #1e40af;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .code-input {
            width: 100%;
            height: 60px;
            border: 2px solid #d1d5db;
            border-radius: 10px;
            font-size: 28px;
            font-weight: 700;
            text-align: center;
            letter-spacing: 10px;
            color: #111827;
            outline: none;
            transition: border-color 0.2s;
            margin-bottom: 20px;
        }

            .code-input:focus {
                border-color: #2563eb;
            }

        button[type="submit"] {
            width: 100%;
            height: 48px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-bottom: 16px;
        }

            button[type="submit"]:hover {
                background: #1d4ed8;
            }

        .timer {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 16px;
        }

            .timer span {
                font-weight: 600;
                color: #111827;
            }

        .resend-form button {
            background: none;
            border: none;
            color: #2563eb;
            font-size: 13px;
            cursor: pointer;
            text-decoration: underline;
            padding: 0;
        }

        .back-link {
            display: block;
            margin-top: 16px;
            font-size: 13px;
            color: #6b7280;
            text-decoration: none;
        }

            .back-link:hover {
                color: #374151;
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">✉</div>
        <h1>Проверьте почту</h1>
        <p class="email-hint">
            Мы отправили 6-значный код на<br />
            <strong>@ViewBag.MaskedEmail</strong>
        </p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        @if (TempData["Info"] != null)
        {
            <div class="info">@TempData["Info"]</div>
        }

        <form method="post" action="/Account/Verify2FA">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Login" value="@Model.Login" />

            <input type="text" name="Code" class="code-input"
                   placeholder="000000" maxlength="6"
                   autocomplete="one-time-code" autofocus
                   inputmode="numeric" pattern="[0-9]*" />

            <button type="submit">Подтвердить</button>
        </form>

        <div class="timer">
            Код действителен: <span id="countdown">@ViewBag.RemainingSeconds</span> сек.
        </div>

        <div class="resend-form">
            <form method="post" action="/Account/ResendCode">
                @Html.AntiForgeryToken()
                <button type="submit">Отправить новый код</button>
            </form>
        </div>

        <a href="/Account/Login" class="back-link">← Вернуться к входу</a>
    </div>

    <script>
        // Обратный отсчёт таймера
        let seconds = parseInt('@ViewBag.RemainingSeconds') || 300;
        const el = document.getElementById('countdown');

        const timer = setInterval(() => {
            seconds--;
            el.textContent = seconds;
            if (seconds <= 10) el.style.color = '#dc2626';
            if (seconds <= 0) {
                clearInterval(timer);
                el.textContent = '0';
                el.parentElement.textContent = 'Код истёк. Запросите новый.';
            }
        }, 1000);

        // Автоматически убираем пробелы из ввода кода
        document.querySelector('.code-input').addEventListener('input', function() {
            this.value = this.value.replace(/\D/g, '');
        });
    </script>
</body>
</html>
